{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run AWR Parser",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_parser.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },
    {
      "name": "Inspect AWR Sections",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/inspect_sections.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
