{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run Analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_analysis.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },

    {
      "name": "Run Parser (Debug)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_parser.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },

    {
      "name": "Inspect Sections",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/inspect_sections.py",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },

    {
      "name": "Run AWR → ADB Loader (Full Pipeline)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.ingest.awr_adb_loader",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "AWR_LOG_LEVEL": "INFO"
      },
      "envFile": "${workspaceFolder}/.env"
    },

    {
      "name": "AWR Rebuild Feature Vectors",
      "type": "debugpy",
      "request": "launch",
      "module": "src.ingest.awr_adb_loader",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "AWR_MAINTENANCE_MODE": "REBUILD_FEATURE_VECTORS",
        "AWR_BACKFILL_AWR_IDS": "70,71",
        "AWR_LOG_LEVEL": "INFO"
      },
      "envFile": "${workspaceFolder}/.env"
    },

    {
      "name": "AWR DB Trend Analysis (FINDB)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.ingest.awr_adb_loader",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "AWR_MAINTENANCE_MODE": "DB_TREND_ANALYSIS",
        "AWR_TREND_DB_NAME": "FINDB",
        "AWR_TREND_DBID": "1234567890",
        "AWR_LOG_LEVEL": "INFO"
      },
      "envFile": "${workspaceFolder}/.env"
    },

    {
      "name": "AWR DB Trend Analysis (DEBUG)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.ingest.awr_adb_loader",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "AWR_MAINTENANCE_MODE": "DB_TREND_ANALYSIS",
        "AWR_TREND_DB_NAME": "FINDB",
        "AWR_TREND_DBID": "1234567890",
        "AWR_LOG_LEVEL": "DEBUG"
      },
      "envFile": "${workspaceFolder}/.env"
    },

    {
      "name": "AWR Trend Analysis (Single Metric Debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.ingest.awr_adb_loader",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "AWR_MAINTENANCE_MODE": "DB_TREND_ANALYSIS",
        "AWR_TREND_DB_NAME": "FINDB",
        "AWR_TREND_DBID": "1234567890",
        "AWR_TREND_METRIC_NAME": "DB_CPU_PCT_DB_TIME",
        "AWR_LOG_LEVEL": "DEBUG"
      },
      "envFile": "${workspaceFolder}/.env"
    }

  ]
}
